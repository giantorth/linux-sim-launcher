# --- Steam Library Discovery ---
def get_steam_libraries() -> list[Path]:
    """Get all Steam library paths from libraryfolders.vdf."""
    vdf_path = Path.home() / ".local/share/Steam/config/libraryfolders.vdf"

    # Also check Flatpak location
    flatpak_vdf = Path.home() / ".var/app/com.valvesoftware.Steam/.local/share/Steam/config/libraryfolders.vdf"
    if Path("/.flatpak-info").is_file() and flatpak_vdf.is_file():
        vdf_path = flatpak_vdf

    libraries = []

    if not vdf_path.is_file():
        default = Path.home() / ".local/share/Steam"
        if default.is_dir():
            libraries.append(default)
        return libraries

    try:
        with open(vdf_path) as f:
            data = vdf.load(f)

        if "libraryfolders" in data:
            folders = data["libraryfolders"]
            for key, value in folders.items():
                if isinstance(value, dict) and "path" in value:
                    lib_path = Path(value["path"])
                    if lib_path.is_dir():
                        libraries.append(lib_path)
    except Exception as e:
        if log:
            log.warning(f"Failed to parse libraryfolders.vdf: {e}")
        default = Path.home() / ".local/share/Steam"
        if default.is_dir():
            libraries.append(default)

    return libraries


def find_library_for_appid(appid: str) -> Optional[Path]:
    """Find which Steam library contains a given AppID."""
    vdf_path = Path.home() / ".local/share/Steam/config/libraryfolders.vdf"

    flatpak_vdf = Path.home() / ".var/app/com.valvesoftware.Steam/.local/share/Steam/config/libraryfolders.vdf"
    if Path("/.flatpak-info").is_file() and flatpak_vdf.is_file():
        vdf_path = flatpak_vdf

    if not vdf_path.is_file():
        return None

    try:
        with open(vdf_path) as f:
            data = vdf.load(f)

        if "libraryfolders" in data:
            folders = data["libraryfolders"]
            for key, value in folders.items():
                if isinstance(value, dict) and "path" in value and "apps" in value:
                    apps = value["apps"]
                    if isinstance(apps, dict) and appid in apps:
                        lib_path = Path(value["path"])
                        if lib_path.is_dir():
                            return lib_path
    except Exception as e:
        if log:
            log.warning(f"Failed to find library for AppID {appid}: {e}")

    return None


def get_compatdata_path(appid: str) -> Optional[Path]:
    """Get the compatdata path for a given AppID."""
    library = find_library_for_appid(appid)
    if library:
        compatdata = library / "steamapps/compatdata" / appid
        if compatdata.is_dir():
            return compatdata

    # Fallback: check all libraries
    for library in get_steam_libraries():
        compatdata = library / "steamapps/compatdata" / appid
        if compatdata.is_dir():
            return compatdata

    return None


def find_simhub_appid() -> Optional[str]:
    """Auto-detect SimHub's Steam AppID from shortcuts.vdf.

    Non-Steam games are stored in Steam's shortcuts.vdf file with their
    generated AppIDs. This function searches for SimHub entries and
    extracts the AppID.
    """
    import struct

    # Determine Steam userdata path
    if Path("/.flatpak-info").is_file():
        userdata_path = Path.home() / ".var/app/com.valvesoftware.Steam/.local/share/Steam/userdata"
    else:
        userdata_path = Path.home() / ".local/share/Steam/userdata"

    if not userdata_path.is_dir():
        return None

    # Check each user's shortcuts.vdf
    for user_dir in userdata_path.iterdir():
        if not user_dir.is_dir():
            continue

        vdf_file = user_dir / "config/shortcuts.vdf"
        if not vdf_file.is_file():
            continue

        try:
            with open(vdf_file, 'rb') as f:
                content = f.read()

            # Look for SimHub entries (case-insensitive search)
            content_lower = content.lower()
            if b'simhub' not in content_lower:
                continue

            # Find all occurrences of 'simhub' and look for nearby appid
            idx = 0
            while True:
                idx = content_lower.find(b'simhub', idx)
                if idx == -1:
                    break

                # Look backwards for 'appid' field
                # Binary VDF format: \x02appid\x00<4 bytes little-endian uint32>
                search_start = max(0, idx - 300)
                chunk = content[search_start:idx + 50]

                appid_marker = b'\x02appid\x00'
                appid_idx = chunk.find(appid_marker)
                if appid_idx != -1:
                    appid_bytes = chunk[appid_idx + len(appid_marker):appid_idx + len(appid_marker) + 4]
                    if len(appid_bytes) == 4:
                        appid = struct.unpack('<I', appid_bytes)[0]
                        if appid > 0:
                            return str(appid)

                idx += 1

        except Exception as e:
            # Log will be initialized later, so we can't use it here
            continue

    return None

# --- Logging Setup ---
def setup_logging(debug_enabled: bool, log_dir: Path) -> logging.Logger:
    """Configure logging with optional file output and log rotation."""
    logger = logging.getLogger("sim-launcher")
    logger.setLevel(logging.DEBUG if debug_enabled else logging.INFO)

    # Console Handler
    c_handler = logging.StreamHandler(stdout)
    c_format = logging.Formatter('[sim-launcher] %(levelname)s: %(message)s')
    c_handler.setFormatter(c_format)
    logger.addHandler(c_handler)

    if debug_enabled:
        # Clean up old log files (keep last 5)
        cleanup_old_logs(log_dir, keep=5)

        # File Handler: log_timestamp.log in program folder
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        log_filename = log_dir / f"log_{timestamp}.log"
        f_handler = logging.FileHandler(log_filename)
        f_format = logging.Formatter('%(asctime)s - [sim-launcher] %(levelname)s: %(message)s')
        f_handler.setFormatter(f_format)
        logger.addHandler(f_handler)
        logger.info(f"Debug logging enabled. Writing to {log_filename}")

    return logger


def cleanup_old_logs(log_dir: Path, keep: int = 5) -> None:
    """Remove old log files, keeping only the most recent ones."""
    try:
        log_files = sorted(log_dir.glob("log_*.log"), key=lambda p: p.stat().st_mtime, reverse=True)
        for old_log in log_files[keep:]:
            old_log.unlink()
    except Exception:
        pass  # Don't fail if we can't clean up logs


