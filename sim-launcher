            LAUNCHERHOME.mkdir(parents=True, exist_ok=True)
            info(f"Created launcher home directory: {LAUNCHERHOME}")
    except PermissionError as e:
        panic(f"Permission denied creating launcher home directory {LAUNCHERHOME}: {e}")
    except Exception as e:
        panic(f"Failed to create launcher home directory {LAUNCHERHOME}: {e}")


def check7z() -> None:
    """Verify 7z is installed and store the binary path."""
    state.zip_binary = which("7z") or which("7za")
    if not state.zip_binary:
        panic("7z is not installed. Please install p7zip or p7zip-full package")
    info(f"Found 7z binary: {state.zip_binary}")

def check_simshmbridge_dependencies() -> list[str]:
    """Check if required tools for building simshmbridge are available."""
    missing = []

    if not which("git"):
        missing.append("git")

    if not which("make"):
        missing.append("make")

    mingw = which("x86_64-w64-mingw32-gcc") or which("i686-w64-mingw32-gcc") or which("mingw32-gcc")
    if not mingw:
        missing.append("mingw-w64-gcc (or gcc-mingw-w64)")

    return missing


def setup_simshmbridge() -> bool:
    """Clone and build simshmbridge if not present."""
    needs_clone = not SIMSHMBRIDGE_DIR.is_dir()
    needs_build = needs_clone or not ACSIMSHMBRIDGE.is_file() or not PC2SIMSHMBRIDGE.is_file()

    if not needs_clone and not needs_build:
        info("simshmbridge is already set up")
        return True

    if needs_clone or needs_build:
        missing_deps = check_simshmbridge_dependencies()
        if missing_deps:
            error("Cannot setup simshmbridge - missing dependencies:")
            for dep in missing_deps:
                error(f"  - {dep}")
            error("Please install the missing packages and try again")
            return False

    # Create clean environment without Steam's LD_PRELOAD and other interference
    clean_env = os.environ.copy()
    for var in ["LD_PRELOAD", "LD_LIBRARY_PATH", "STEAM_RUNTIME_LIBRARY_PATH"]:
        clean_env.pop(var, None)

    if needs_clone:
        info(f"Cloning simshmbridge from {SIMSHMBRIDGE_REPO} into {SIMSHMBRIDGE_DIR}...")
        try:
            if SIMSHMBRIDGE_DIR.is_dir():
                info("Directory appeared since check, skipping clone")
            else:
                clone_cmd = ["git", "clone", "--recursive", SIMSHMBRIDGE_REPO, str(SIMSHMBRIDGE_DIR)]
                proc = Popen(clone_cmd, cwd=LAUNCHERHOME, stdout=PIPE, stderr=PIPE, env=clean_env)
                _, stderr_out = proc.communicate()

                if proc.returncode != 0:
                    error(f"Failed to clone simshmbridge (exit code: {proc.returncode})")
                    if stderr_out:
                        error(f"Git error: {stderr_out.decode('utf-8', errors='ignore').strip()}")
                    return False

                info("Successfully cloned simshmbridge")
        except Exception as e:
            error(f"Error cloning simshmbridge: {e}")
            return False
    elif needs_build:
        info("Updating simshmbridge submodules...")
        try:
            submodule_cmd = ["git", "submodule", "update", "--init", "--recursive"]
            Popen(submodule_cmd, cwd=SIMSHMBRIDGE_DIR, env=clean_env).wait()
        except Exception as e:
            error(f"Warning: Could not update submodules: {e}")

    if needs_build:
        info("Building simshmbridge (this may take a moment)...")
        try:
            clean_cmd = ["make", "clean"]
            build_cmd = ["make"]

            info("Running: make clean")
            proc = Popen(clean_cmd, cwd=SIMSHMBRIDGE_DIR, stdout=DEVNULL, stderr=PIPE, env=clean_env)
            _, stderr_out = proc.communicate()
            if proc.returncode != 0 and stderr_out:
                error(f"make clean warning: {stderr_out.decode('utf-8', errors='ignore').strip()}")

            info("Running: make")
            proc = Popen(build_cmd, cwd=SIMSHMBRIDGE_DIR, stdout=DEVNULL, stderr=PIPE, env=clean_env)
            _, stderr_out = proc.communicate()

            if proc.returncode != 0:
                error(f"Failed to build simshmbridge (exit code: {proc.returncode})")
                if stderr_out:
                    error(f"Build error: {stderr_out.decode('utf-8', errors='ignore').strip()}")
                error("Check that mingw-w64-gcc is properly installed")
                return False

            if not ACSIMSHMBRIDGE.is_file() or not PC2SIMSHMBRIDGE.is_file():
                error("Build completed but expected binaries were not found")
                error(f"Expected: {ACSIMSHMBRIDGE} and {PC2SIMSHMBRIDGE}")
                return False

            info("Successfully built simshmbridge")
            return True

        except Exception as e:
            error(f"Error building simshmbridge: {e}")
            return False

    return True

def validate_paths() -> bool:
    """Validate critical paths and executables based on enabled features."""
    issues = []

    if args.acbridge:
        if not ACSIMSHM.is_file():
            issues.append(f"AC Bridge executable not found: {ACSIMSHM}")
        if not ACSIMSHMBRIDGE.is_file():
            issues.append(f"AC SimHub Bridge executable not found: {ACSIMSHMBRIDGE}")

    if args.pc2bridge:
        if not PC2SIMSHM.is_file():
            issues.append(f"PC2 Bridge executable not found: {PC2SIMSHM}")
        if not PC2SIMSHMBRIDGE.is_file():
            issues.append(f"PC2 SimHub Bridge executable not found: {PC2SIMSHMBRIDGE}")

    if args.simhub and not args.simhub_same_prefix:
        if not which("protontricks-launch"):
            issues.append("protontricks-launch not found - required for SimHub in separate prefix")
        if args.simhub_pfx and not args.simhub_pfx.is_dir():
            issues.append(f"SimHub prefix directory not found: {args.simhub_pfx}")

    if args.lookpilot:
        if not which("steam"):
            issues.append("steam command not found - required for LookPilot")

    if args.monocoque:
        if not which("monocoque"):
            issues.append("monocoque command not found")

    if args.kiosk_ip and not args.kiosk_pw:
        issues.append("--kiosk-ip specified but --kiosk-pw not provided")
    if args.kiosk_pw and not args.kiosk_ip:
        issues.append("--kiosk-pw specified but --kiosk-ip not provided")

    if issues:
        error("Validation issues found:")
        for issue in issues:
            error(f"  - {issue}")
        if any("not found" in issue.lower() for issue in issues):
            info("Some features may not work correctly. Continuing anyway...")
    else:
        info("Path validation passed")

    return len(issues) == 0


def kill_process_tree(pid: int, timeout: int = 5) -> bool:
    """Kill a process and all its children gracefully, then forcefully if needed."""
    try:
        os.killpg(os.getpgid(pid), signal.SIGTERM)

        start_time = time.time()
        while time.time() - start_time < timeout:
            try:
                os.killpg(os.getpgid(pid), 0)
                time.sleep(0.1)
            except ProcessLookupError:
                return True

        info(f"Process {pid} didn't exit gracefully, forcing SIGKILL")
        os.killpg(os.getpgid(pid), signal.SIGKILL)
        return True
    except ProcessLookupError:
        return True
    except Exception as e:
        error(f"Error killing process {pid}: {e}")
        return False


def kill_by_name(name: str, force: bool = False) -> bool:
    """Kill processes by name using pkill."""
    try:
        check_cmd = ["pgrep", "-f", name]
        result = subprocess.run(check_cmd, capture_output=True, text=True)

        if result.returncode != 0:
            return False

        pids = result.stdout.strip().split('\n')
        info(f"Found {len(pids)} process(es) matching '{name}': {', '.join(pids)}")

        signal_flag = "-9" if force else "-TERM"
        kill_cmd = ["pkill", signal_flag, "-f", name]
        subprocess.run(kill_cmd, capture_output=True)

        time.sleep(0.5)
        verify_result = subprocess.run(check_cmd, capture_output=True)

        if verify_result.returncode == 0 and not force:
            info(f"Processes still running, forcing kill for '{name}'")
            subprocess.run(["pkill", "-9", "-f", name], capture_output=True)
            time.sleep(0.5)

        return True
    except Exception as e:
        error(f"Error killing processes by name '{name}': {e}")
        return False


def cleanup_shm_files() -> None:
    """Clean up shared memory files created by AC bridge."""
    # Skip cleanup if simd is running (it needs these files)
    try:
        result = subprocess.run(["pgrep", "-x", "simd"], capture_output=True)
        if result.returncode == 0:
            info("simd is running, skipping shm file cleanup")
            return
    except Exception as e:
        error(f"Error checking for simd process: {e}")

    shm_files = [
        "/dev/shm/acpmf_crewchief",
        "/dev/shm/acpmf_graphics",
        "/dev/shm/acpmf_physics",
        "/dev/shm/acpmf_static",
        "/dev/shm/acpmf_simhub_v2",
    ]
    info("Cleaning up AC shm files")
    for shm_file in shm_files:
        try:
            shm_path = Path(shm_file)
            if shm_path.exists():
                shm_path.unlink()
                info(f"Removed {shm_file}")
        except PermissionError as e:
            error(f"Permission denied removing {shm_file}: {e}")
        except Exception as e:
            error(f"Failed to remove {shm_file}: {e}")


def terminate_process(proc: Optional[Popen], name: str, timeout: int = 3) -> None:
    """Terminate a process gracefully, then forcefully if needed."""
    if not proc:
        return

    try:
        if proc.poll() is None:
            info(f"Terminating {name}...")
            proc.terminate()
            try:
                proc.wait(timeout=timeout)
                info(f"{name} terminated successfully")
            except subprocess.TimeoutExpired:
                info(f"{name} didn't exit, force killing...")
                proc.kill()
                proc.wait()
        else:
            info(f"{name} already exited with code {proc.returncode}")
    except Exception as e:
        error(f"Error terminating {name}: {e}")


def perform_cleanup(args: argparse.Namespace) -> None:
    """Clean up all launched processes and resources."""
    info("Initiating global cleanup...")

    # Turn off Kiosk Browser
    if args.kiosk_ip and args.kiosk_pw:
        try:
            result = screen_off(args)
            if result:
                info("Kiosk screen turned off successfully")
            else:
                error("Failed to turn off kiosk screen")
        except Exception as e:
            error(f"Error turning off kiosk screen: {e}")

    # Kill Native Linux Bridge Groups
    if state.ac_shm_proc:
        info("Terminating AC Bridge...")
        try:
            if kill_process_tree(state.ac_shm_proc.pid):
                info("AC Bridge terminated successfully")
            else:
                error("Failed to terminate AC Bridge")
        except Exception as e:
            error(f"Error terminating AC Bridge: {e}")

        if args.clean_shm:
            cleanup_shm_files()

    if state.pc2_shm_proc:
        info("Terminating PC2 Bridge...")
        try:
            if kill_process_tree(state.pc2_shm_proc.pid):
                info("PC2 Bridge terminated successfully")
            else:
                error("Failed to terminate PC2 Bridge")
        except Exception as e:
            error(f"Error terminating PC2 Bridge: {e}")

    # Kill Monocoque
    terminate_process(state.monocoque_proc, "Monocoque")

    # Kill SimHub and Bridge processes (only if launched externally)
    if args.simhub and not args.simhub_same_prefix:
        info("Terminating SimHub...")
        try:
            if kill_by_name("SimHubWPF.exe"):
                info("SimHub terminated successfully")
            else:
                info("SimHub was not running or already terminated")
        except Exception as e:
            error(f"Error terminating SimHub: {e}")

        terminate_process(state.bridge_proc, "Proton Bridge")
    elif args.simhub and args.simhub_same_prefix:
        info("SimHub cleanup handled in game prefix")

    # Kill LookPilot
    if args.lookpilot:
        info("Terminating LookPilot...")
        try:
            if kill_by_name("LookPilot"):
                info("LookPilot terminated successfully")
            else:
                info("LookPilot was not running or already terminated")
        except Exception as e:
            error(f"Error terminating LookPilot: {e}")

    # Kill other Windows/Wine executables by name
    targets = [
        "acbridge.exe",
        "pcars2bridge.exe",
        "opentrack.exe",
        "TrackIR.exe",
    ]

    if state.proton_bridge:
        targets.append(state.proton_bridge.name)

    for exe in targets:
        try:
            if kill_by_name(exe):
                info(f"Terminated {exe}")
        except Exception as e:
            error(f"Error terminating {exe}: {e}")

    # Remove the hardlink
    if state.proton_bridge and state.proton_bridge.exists():
        try:
            info(f"Cleaning up {state.proton_bridge}")
            state.proton_bridge.unlink()
            info("Cleaned up bridge link.")
        except PermissionError as e:
            error(f"Permission denied cleaning up {state.proton_bridge}: {e}")
        except Exception as e:
            error(f"Failed to clean up {state.proton_bridge}: {e}")


def main() -> None:
    """Main entry point."""
    check7z()
    makehome()

    # Setup simshmbridge if any bridge is requested or SimHub needs it
    needs_bridge = args.acbridge or args.pc2bridge or (args.simhub and not args.simhub_same_prefix)
    if needs_bridge:
        info("Setting up simshmbridge...")
        if not setup_simshmbridge():
            panic("Failed to setup simshmbridge - cannot continue with bridge support")

    validate_paths()

    appid = findappid()
    opentrackexec = getopentrack()
    simhubexec = getsimhub(appid)

    launcherscript = getlaunchscript(appid, opentrackexec, simhubexec)

    # Dry run mode - show what would be launched
    if args.dry_run:
        info("=== DRY RUN MODE ===")
        info(f"AppID: {appid}")
        info(f"Launch script: {launcherscript}")
        if opentrackexec:
            info(f"OpenTrack: {opentrackexec}")
        if simhubexec:
            info(f"SimHub: {simhubexec}")
        if args.acbridge:
            info(f"AC Bridge: {ACSIMSHM}")
        if args.pc2bridge:
            info(f"PC2 Bridge: {PC2SIMSHM}")
        if args.monocoque:
            info("Monocoque: enabled")
        if args.lookpilot:
            info("LookPilot: enabled")
        if args.kiosk_ip:
            info(f"Kiosk: {args.kiosk_ip}:{args.kiosk_port}")
        info("=== END DRY RUN ===")
        return

    # Launch LookPilot
    if args.lookpilot:
        info("Launching LookPilot...")
        try:
            state.lookpilot_proc = Popen(["steam", "steam://rungameid/3326890"])
            info(f"LookPilot launched (PID: {state.lookpilot_proc.pid})")
        except FileNotFoundError:
            error("Failed to launch LookPilot: steam command not found")
        except Exception as e:
            error(f"Failed to launch LookPilot: {e}")

    # Start ACSIMSHM (Native Linux) in its own process group
    if args.acbridge:
        info("Launching AC Bridge (Native)")
        if not ACSIMSHM.is_file():
            error(f"AC Bridge executable not found: {ACSIMSHM}")
        else:
            try:
                state.ac_shm_proc = Popen(str(ACSIMSHM), start_new_session=True,
                                          stdout=DEVNULL, stderr=DEVNULL)
                info(f"AC Bridge launched (PID: {state.ac_shm_proc.pid})")
                time.sleep(0.2)
                if state.ac_shm_proc.poll() is not None:
                    error(f"AC Bridge exited immediately with code {state.ac_shm_proc.returncode}")
                    state.ac_shm_proc = None
            except PermissionError:
                error(f"Permission denied launching AC Bridge: {ACSIMSHM}")
            except Exception as e:
                error(f"Failed to launch AC Bridge: {e}")

    # Start PC2SIMSHM (Native Linux) in its own process group
    if args.pc2bridge:
        info("Launching PC2 Bridge (Native)")
        if not PC2SIMSHM.is_file():
            error(f"PC2 Bridge executable not found: {PC2SIMSHM}")
        else:
            try:
                state.pc2_shm_proc = Popen(str(PC2SIMSHM), start_new_session=True,
                                           stdout=DEVNULL, stderr=DEVNULL)
                info(f"PC2 Bridge launched (PID: {state.pc2_shm_proc.pid})")
                time.sleep(0.2)
                if state.pc2_shm_proc.poll() is not None:
                    error(f"PC2 Bridge exited immediately with code {state.pc2_shm_proc.returncode}")
                    state.pc2_shm_proc = None
            except PermissionError:
                error(f"Permission denied launching PC2 Bridge: {PC2SIMSHM}")
            except Exception as e:
                error(f"Failed to launch PC2 Bridge: {e}")

    # Launch SimHub and Proton Bridge BEFORE the main game (only if NOT in same prefix)
    if args.simhub and simhubexec and not args.simhub_same_prefix:
        pt_launcher = which("protontricks-launch")
        if not pt_launcher:
            error("protontricks-launch not found - cannot launch SimHub in separate prefix")
        else:
            try:
                clean_env = os.environ.copy()
                for var in ["LD_LIBRARY_PATH", "PYTHONPATH", "PYTHONHOME", "STEAM_RUNTIME_LIBRARY_PATH"]:
                    clean_env.pop(var, None)

                # Create hardlink for bridge
                if state.proton_bridge and state.proton_bridge.exists():
                    state.proton_bridge.unlink()

                bridge_source = ACSIMSHMBRIDGE if args.acbridge else (PC2SIMSHMBRIDGE if args.pc2bridge else DUMMYBRIDGE)
                if not bridge_source.is_file():
                    error(f"Bridge source not found: {bridge_source}")
                elif state.proton_bridge:
                    try:
                        os.link(bridge_source, state.proton_bridge)
                        info(f"Created bridge link: {state.proton_bridge}")
                    except OSError as e:
                        error(f"Failed to create bridge hardlink: {e}")
                        state.proton_bridge = None

                if state.proton_bridge:
                    info(f"Launching Proton Bridge for SimHub: {state.proton_bridge}")
                    try:
                        state.bridge_proc = Popen(
                            [pt_launcher, "--appid", str(state.simhub_appid), str(state.proton_bridge)],
                            env=clean_env, start_new_session=True,
                            stdout=DEVNULL, stderr=DEVNULL)
                        info(f"Bridge launched (PID: {state.bridge_proc.pid})")
                        time.sleep(1)
                    except Exception as e:
                        error(f"Failed to launch Proton Bridge: {e}")
                        state.bridge_proc = None

                info(f"Launching SimHub: {args.simhub_exe} (AppID: {state.simhub_appid})")
                try:
                    state.simhub_proc = Popen(
                        [pt_launcher, "--appid", str(state.simhub_appid), str(simhubexec)],
                        env=clean_env, start_new_session=True,
                        stdout=DEVNULL, stderr=DEVNULL)
                    info(f"SimHub launched (PID: {state.simhub_proc.pid})")
                    info("Waiting for SimHub to initialize...")
                    time.sleep(10)
                except Exception as e:
                    error(f"Failed to launch SimHub: {e}")
                    state.simhub_proc = None

            except Exception as e:
                error(f"Error setting up SimHub/Bridge: {e}")

    elif args.simhub and simhubexec and args.simhub_same_prefix:
        info("SimHub will be launched from batch script with delay before game starts")

    # Prepare and launch the main game
    final_argv = list(argv_original)
    exe_found = False
    for i in range(len(final_argv) - 1, -1, -1):
        if final_argv[i].endswith(".exe"):
            final_argv[i] = str(launcherscript)
            exe_found = True
            break

    if not exe_found:
        panic("Could not find executable in command line arguments")

    info(f"Final execution command: {' '.join(final_argv[1:])}")
    try:
        state.main_game_proc = Popen(final_argv[1:])
        info(f"Main game launched (PID: {state.main_game_proc.pid})")
    except FileNotFoundError as e:
        panic(f"Failed to launch game - command not found: {e}")
    except Exception as e:
        panic(f"Failed to launch main game: {e}")

    # Turn on Kiosk Browser
    if args.kiosk_ip and args.kiosk_pw:
        info("Turning on kiosk tablet screen")
        try:
            result = screen_on(args)
            if result:
                info("Kiosk screen turned on successfully")
            else:
                error("Failed to turn on kiosk screen")
        except Exception as e:
            error(f"Error turning on kiosk screen: {e}")

    # Launch Monocoque
    if args.monocoque:
        info("Launching Monocoque")
        try:
            state.monocoque_proc = Popen(
                ["monocoque", "play"],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                bufsize=1)

            time.sleep(0.5)

            if state.monocoque_proc.poll() is not None:
                error(f"Monocoque exited immediately with code {state.monocoque_proc.returncode}")
                state.monocoque_proc = None
            else:
                info(f"Monocoque started successfully (PID: {state.monocoque_proc.pid})")
        except FileNotFoundError:
            error("Failed to launch Monocoque: monocoque command not found")
            state.monocoque_proc = None
        except Exception as e:
            error(f"Failed to launch Monocoque: {e}")
            state.monocoque_proc = None

    # Wait for main game to exit
    try:
        info("Waiting for main game to exit...")
        state.main_game_proc.wait()
        info(f"Main game exited with code {state.main_game_proc.returncode}")
    except KeyboardInterrupt:
        info("Shutdown requested via keyboard...")
        try:
            state.main_game_proc.terminate()
            info("Sent termination signal to main game")
            state.main_game_proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            info("Main game didn't exit, force killing...")
            state.main_game_proc.kill()
        except Exception as e:
            error(f"Error terminating main game: {e}")
    except Exception as e:
        error(f"Error waiting for main game: {e}")
    finally:
        info("Main game closed.")
        perform_cleanup(args)

    info("Cleanup complete. Exiting.")


if __name__ == '__main__':
    try:
        main()
    except Exception as e:
        error(f"Fatal error in main execution: {e}")
        import traceback
        error(f"Traceback: {traceback.format_exc()}")
        exit(1)